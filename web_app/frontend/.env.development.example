# this file will be running at local
# Google OAuth Client ID (safe to share — not a secret)
#
# How to get it:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (e.g. "FlashPOD App")
#   3. Enable "Google Sheets API" and "Google Drive API" under APIs & Services → Library
#   4. Go to APIs & Services → OAuth consent screen → External → fill in app name & email
#   5. Go to APIs & Services → Credentials → + Create Credentials → OAuth client ID
#   6. Application type: Web application
#   7. Under "Authorised JavaScript origins" add:
#        http://localhost:3000   (production via start.command)
#        http://localhost:5173   (local dev via pnpm dev)
#   8. Click Create — copy the Client ID (ends in .apps.googleusercontent.com)
#
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Google Sheet ID for fulfillment tracking
# How to get it: open the sheet in browser, copy the ID from the URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
VITE_GOOGLE_SHEET_FULLFILL_ID=your-sheet-id-here

# Google Sheet ID for the design library (local test sheet)
VITE_GOOGLE_SHEET_DESIGN_ID=your-design-sheet-id-here

# (Optional) Tab name inside the design spreadsheet (default: Sheet1)
VITE_GOOGLE_SHEET_DESIGN_SHEET_NAME=Sheet1

# (Optional) Legacy Google Sheet ID for fulfillment tracking
VITE_GOOGLE_SHEET_LEGACY_FULLFILL_ID=legacy-fullfill-id-here

VITE_GOOGLE_DRIVE_UPLOAD_FOLDER_ID=folder-id-to-upload-images-to
